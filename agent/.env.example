# Ollama（agent 模块）
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.2
# 上下文窗口；Skill 分层按需加载 MCP 工具，默认 8192 通常足够
OLLAMA_NUM_CTX=8192
# 打印每次 LLM 调用的输入/输出（设为 false 关闭）
LLM_IO_LOG=true

# 禅道 MCP（@zzp123/mcp-zentao 开发工程师版 index-dev）
# 首次使用需通过 initZentao 工具初始化，配置保存在 ~/.zentao/config.json
ZENTAO_MCP_ENABLED=true
