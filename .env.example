PORT=3000

# 数据库模式: pglite（默认，嵌入式）| postgres（远程 PostgreSQL）
DATABASE_MODE=pglite

# PGlite 数据目录（仅 pglite 模式）
DATABASE_DIR=./data/pglite

# 远程 PostgreSQL 连接串（仅 postgres 模式）
# DATABASE_URL=postgres://user:password@localhost:5432/developer_assistant

# 旧版 lowdb JSON 路径，首次启动时自动导入
LEGACY_DATABASE_PATH=./data/db.json

