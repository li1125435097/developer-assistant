{
  "name": "developer-assistant",
  "version": "1.0.0",
  "description": "开发者脚本助手",
  "type": "module",
  "main": "backend/dist/index.js",
  "scripts": {
    "start": "node backend/dist/index.js",
    "dev": "tsx watch backend/src/index.ts",
    "build:backend": "tsc -p backend/tsconfig.json",
    "db:generate": "drizzle-kit generate --config backend/drizzle.config.ts",
    "db:push": "drizzle-kit push --config backend/drizzle.config.ts",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "postinstall": "npm install --prefix frontend"
  },
  "keywords": [
    "scripts",
    "fastify",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "@electric-sql/pglite": "^0.3.7",
    "@fastify/static": "^8.0.4",
    "clipboardy": "^5.3.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.2.1",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
